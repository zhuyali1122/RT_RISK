# PostgreSQL 连接配置
# 复制此文件为 .env 并填入实际值

# 方式一：使用 DATABASE_URL（推荐）
DATABASE_URL=postgresql+asyncpg://user:password@host:5432/database?sslmode=require
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10
# DB_SSLMODE=require  # 可选，覆盖 URL 中的 sslmode
# DB_HOST_IP=1.2.3.4  # 域名解析失败时，用 IP 直连。运行 python3 check_db_network.py --ip-only 获取

# 方式二：使用独立变量
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=your_database
# DB_USER=your_username
# DB_PASSWORD=your_password

# 飞书多维表格 - 生产商拓展列表（可选）
# 在飞书开放平台创建应用后获取：https://open.feishu.cn/app
# FEISHU_APP_ID=your_app_id
# FEISHU_APP_SECRET=your_app_secret
# 若表格在 Wiki 中：FEISHU_WIKI_NODE=Py0TwI8uRiyW9Qkj8W3cVIAJnzp
# 表格 ID（URL 中 table= 参数）：FEISHU_TABLE_ID=tbl7nNDG29dEYFva
# 或直接提供多维表格 app_token：FEISHU_APP_TOKEN=xxx

# Vercel 共享缓存（可选，部署到 Vercel 时建议配置 KV）
# 添加 Vercel KV 后会自动注入；或使用 Upstash 直接创建时手动配置
# KV_REST_API_URL=https://xxx.upstash.io
# KV_REST_API_TOKEN=xxx
# 或：UPSTASH_REDIS_REST_URL、UPSTASH_REDIS_REST_TOKEN

# Vercel Cron 每日定时刷新（必填，用于鉴权，至少 16 字符）
# CRON_SECRET=your_random_secret_at_least_16_chars
